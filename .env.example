# ── Авторизация ───────────────────────────────────────────────
# Логин и пароль для входа в панель (обязательно)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# Внутренний токен сессии (сгенерируй случайный: openssl rand -hex 32)
AUTH_TOKEN=change-me-random-token

# ── MTG Agent ─────────────────────────────────────────────────
# Токен для агентов на нодах (должен совпадать с .env агента)
AGENT_TOKEN=mtg-agent-secret

# ── Панель ───────────────────────────────────────────────────
PORT=3000
DATA_DIR=/data

# URL панели — используется для CORS (без слеша в конце)
PANEL_URL=https://panel.example.com

# GitHub repo slug для релизов и скачивания agent-файлов
REPO_SLUG=Bogdan199719/mtproxy-panel
